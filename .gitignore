# ── Dataset ──────────────────────────────────────────
# Large CSV files — download separately from Kaggle
data/*.csv
data/*.tsv
data/*.json

# ── Trained Models ───────────────────────────────────
# .pkl files are auto-generated by train_model.py
# They can be large (100MB+) and should not be in git
models/*.pkl
models/*.joblib

# ── Python ───────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Virtual Environment ───────────────────────────────
venv/
env/
.env/
.venv/

# ── Environment Variables ─────────────────────────────
.env
.env.local
*.env

# ── IDE & Editor Files ────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# ── Jupyter Notebooks (if any) ───────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Logs ─────────────────────────────────────────────
*.log
logs/

# ── Distribution / Build ──────────────────────────────
dist/
build/
*.egg-info/
